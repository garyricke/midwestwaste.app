# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, bypasses RLS

# ---- Stripe ----
# Use test keys (sk_test_…) while developing, then swap to live (sk_live_…).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # from `stripe listen` or the dashboard webhook

# ---- Resend (email) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM=Midwest Waste <orders@midwestwaste.app>
# Route ALL hauler notifications here during fake-hauler testing.
# Blank this out once real haulers are loaded so emails go to each hauler.
HAULER_NOTIFY_OVERRIDE=gary.ricke@orbisdesign.com
# Who gets the "no hauler in range" alerts (defaults to HAULER_NOTIFY_OVERRIDE).
ADMIN_EMAIL=gary.ricke@orbisdesign.com

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000         # set to https://midwestwaste.app in prod

# ---- Pre-launch gate (Netlify edge function) ----
GATE_PASSWORD=ilovegarbage

# ---- Admin orders dashboard (/admin) — separate from the site gate ----
ADMIN_PASSWORD=change-me
# GATE_DISABLED=true                               # set at go-live to remove the gate
